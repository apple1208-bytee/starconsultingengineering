# ── Supabase ──────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service role key (server-only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) — optional ─────────────────────────────
# If unset, inquiry emails are skipped (submissions still saved to Supabase).
RESEND_API_KEY=
# Verified sender, e.g. "Star Consulting <hello@yourdomain.com>"
EMAIL_FROM=
# Where new-inquiry notifications are sent
ADMIN_EMAIL=
